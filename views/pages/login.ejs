<%- include("../partials/head") %>

<main class="account">

  <div class="account-left">
    <img src="images/gradient-wave.png" alt="Collego illustratie" />
    <span class="logo">Collego</span>
    <div class="text">
      <h2>Welkom terug!</h2>
      <p>Log in en ontdek vacatures die aansluiten bij jouw ervaring en ambities.</p>
    </div>
  </div>

  <section class="account-right">
    <div class="container">

      <h1>Log in bij <span>Collego</span></h1>
      <p class="subtitle">Nog geen account? Registreer je gratis en start met matchen.</p>

      <form action="/login" method="POST">

        <div class="field">
          <div class="role-tabs">
            <div class="role-slider" id="roleSlider"></div>
            <div class="role-tab">
              <input type="radio" id="role-user" name="role" value="user" <%= typeof role === 'undefined' || role === 'user' ? 'checked' : '' %> />
              <label for="role-user">Werkzoekende</label>
            </div>
            <div class="role-tab">
              <input type="radio" id="role-company" name="role" value="company" <%= role === 'company' ? 'checked' : '' %> />
              <label for="role-company">Bedrijf</label>
            </div>
          </div>
        </div>

        <div class="field">
          <label for="email">Emailadres</label>
          <input type="email" id="email" name="email" placeholder="voorbeeld@voorbeeld.nl" value="<%= typeof email !== 'undefined' ? email : '' %>" required />
        </div>

        <div class="field">
          <label for="password">Wachtwoord</label>
          <input type="password" id="password" name="password" placeholder="Vul je wachtwoord in" required />
        </div>

        <% if (typeof error !=='undefined' ) { %>
        <div class="error">
          <%= error %>
        </div>
        <% } %>

        <button type="submit" class="btn">Inloggen</button>
      </form>

      <p class="link">Nog geen account? <a href="/register" id="registerLink">Registreer nu!</a></p>

    </div>
  </section>
</main>

<script src="/js/login.js"></script>

<%- include("../partials/foot") %>