<%- include("../partials/header") %>
<main class="home-page">

  <section class="hero">
    <div class="hero-content">
      <h1>Jouw nieuwe baan begint hier!</h1>
      <p>Met Collego match je eenvoudig met bedrijven die aansluiten bij jouw interesses, vaardigheden en ambities.</p>
      <div class="hero-buttons">
        <a href="/matching" class="hero-button-primary">Begin te matchen</a>
        <a href="/register" class="hero-button-secondary">Maak een profiel</a>
      </div>
    </div>
  </section>

  <section class="how-it-works">
    <p class="how-it-works-label">Hoe het werkt</p>
    <h2 class="how-it-works-title">Vind vacatures die bij jou passen</h2>
    <div class="how-it-works-grid">
      <div class="how-it-works-card">
        <span class="how-it-works-card-number">1</span>
        <h3 class="how-it-works-card-title">Maak een profiel</h3>
        <p class="how-it-works-card-text">Vul je werkervaring, vaardigheden en voorkeuren in zodat we de beste vacatures voor jou vinden.</p>
      </div>
      <div class="how-it-works-card">
        <span class="how-it-works-card-number">2</span>
        <h3 class="how-it-works-card-title">Ontdek vacatures</h3>
        <p class="how-it-works-card-text">Bekijk en filter vacatures op salaris, locatie, uren en meer. Overzichtelijk op één plek.</p>
      </div>
      <div class="how-it-works-card">
        <span class="how-it-works-card-number">3</span>
        <h3 class="how-it-works-card-title">Direct contact met werkgevers</h3>
        <p class="how-it-works-card-text">Match met een werkgever en word direct uitgenodigd voor een gesprek.</p>
      </div>
    </div>
  </section>

  <section class="steps">
    <div class="steps-line"></div>
    <div class="steps-grid">
      <div class="step">
        <div class="step-number">1</div>
        <h3 class="step-title">Voor werkzoekenden gemaakt</h3>
        <p class="step-text">Vacatures speciaal geselecteerd op jouw profiel en voorkeuren.</p>
      </div>
      <div class="step">
        <div class="step-number">2</div>
        <h3 class="step-title">Snel solliciteren</h3>
        <p class="step-text">Reageer met één klik op vacatures zonder lange formulieren.</p>
      </div>
      <div class="step">
        <div class="step-number">3</div>
        <h3 class="step-title">Alleen relevante banen</h3>
        <p class="step-text">Filter op salaris, uren, locatie en vakgebied.</p>
      </div>
      <div class="step">
        <div class="step-number">4</div>
        <h3 class="step-title">Direct contact met werkgevers</h3>
        <p class="step-text">Bij een match word je uitgenodigd voor een gesprek.</p>
      </div>
    </div>
  </section>

  <section class="trending">
    <p class="trending-label">Trending</p>
    <h2 class="trending-title">Populaire vacatures</h2>
    <div class="trending-grid">
      <%# Loop door de trending vacatures die vanuit de server worden meegegeven %>
      <% for (const vacancy of trendingVacancies) { %>
      <div class="trending-card">
        <span class="trending-tag">Deeltijd</span>
        <h3 class="trending-card-title"><%= vacancy.title %></h3>
        <p class="trending-card-company"><%= vacancy.company %></p>
        <p class="trending-card-location"><%= vacancy.location %></p>
        <div class="trending-card-buttons">
          <a href="/matching" class="trending-card-button-yes">&#10003;</a>
          <a href="/matching" class="trending-card-button-no">&#10005;</a>
        </div>
      </div>
      <% } %>
    </div>
  </section>

</main>
<%- include("../partials/footer") %>