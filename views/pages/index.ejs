<%- include("../partials/header") %>
<main class="home-page">

  <section class="hero">
    <div class="hero-content">
      <h1>Jouw nieuwe baan begint hier!</h1>
      <p>Met Collego match je eenvoudig met bedrijven die aansluiten bij jouw interesses, vaardigheden en ambities.</p>
      <div class="hero-buttons">
        <a href="/matching" class="hero-button-primary">Begin te matchen</a>
        <a href="/create-profile" class="hero-button-secondary">Maak een profiel</a>
      </div>
    </div>
  </section>

  <section class="how-it-works">
    <p class="how-it-works-label">Hoe het werkt</p>
    <h2 class="how-it-works-title">Vind vacatures die bij jou passen</h2>
    <div class="how-it-works-grid">
      <div class="how-it-works-card">
        <span class="how-it-works-card-number">1</span>
        <h3 class="how-it-works-card-title">Maak een profiel</h3>
        <p class="how-it-works-card-text">Vul je werkervaring, vaardigheden en voorkeuren in zodat we de beste vacatures voor jou vinden.</p>
      </div>
      <div class="how-it-works-card">
        <span class="how-it-works-card-number">2</span>
        <h3 class="how-it-works-card-title">Ontdek vacatures</h3>
        <p class="how-it-works-card-text">Bekijk en filter vacatures op salaris, locatie, uren en meer. Overzichtelijk op één plek.</p>
      </div>
      <div class="how-it-works-card">
        <span class="how-it-works-card-number">3</span>
        <h3 class="how-it-works-card-title">Direct contact met werkgevers</h3>
        <p class="how-it-works-card-text">Match met een werkgever en word direct uitgenodigd voor een gesprek.</p>
      </div>
    </div>
  </section>

</main>
<%- include("../partials/footer") %>