<%- include("../partials/header") %>

  <main class="matching-page">

    <section class="hero">
      <h1>Matching</h1>
      <p>Bekijk vacatures en laat ons weten of je geïnteresseerd bent!</p>
    </section>

    <section class="vacancies-list">

      <% vacancies.forEach(function(vacancy) { %>

        <div class="vacancy-card"
          data-category="<%= vacancy.category %>"
          data-education="<%= vacancy.education || '' %>"
          data-hours="<%= vacancy.hoursPerWeek || '' %>"
          data-contract="<%= vacancy.contractType || '' %>"
        >

          <div class="card-info">

            <div class="card-title-row">
              <h2><%= vacancy.title %></h2>
              <button class="favorite-button" 
                data-vacancy-id="<%= vacancy._id %>"
                data-vacancy-title="<%= vacancy.title %>" 
                data-company="<%= vacancy.company %>"
                data-location="<%= vacancy.location %>"
                data-salary="<%= vacancy.salary %>"
                data-hours-per-week="<%= vacancy.hoursPerWeek %>"
                data-contract-type="<%= vacancy.contractType %>">
                <span class="material-symbols-outlined favorite-icon">favorite</span>
              </button>
            </div>

            <p class="feedback-message"></p>

            <p class="company"><%= vacancy.company %></p>
            <p class="location"><%= vacancy.location %></p>
            <p class="category"><%= vacancy.category %></p>

            <% if (vacancy.hoursPerWeek) { %>
              <p class="hours"><%= vacancy.hoursPerWeek %></p>
            <% } %>

            <% if (vacancy.contractType) { %>
              <p class="contract"><%= vacancy.contractType %></p>
            <% } %>

            <% if (vacancy.salary) { %>
              <p class="salary">€<%= vacancy.salary %> per maand</p>
            <% } %>

          </div>

          <div class="popup">
            <div class="popup-content">
              <button class="close-button">
                <span class="material-symbols-outlined">close</span>
              </button>
              <h2><%= vacancy.title %></h2>
              <p class="company"><%= vacancy.company %></p>
              <p class="location"><%= vacancy.location %></p>
              <p class="description"><%= vacancy.description %></p>
            </div>
          </div>

          <div class="card-buttons">
            <button class="no-button" 
              data-vacancy-id="<%= vacancy._id %>" 
              data-vacancy-title="<%= vacancy.title %>"
              data-company="<%= vacancy.company %>"
              data-location="<%= vacancy.location %>"
              data-salary="<%= vacancy.salary %>"
              data-hours-per-week="<%= vacancy.hoursPerWeek %>"
              data-contract-type="<%= vacancy.contractType %>">
              &#10005;
            </button>
            <button class="more-info-button">Meer info</button>
            <button class="yes-button" 
              data-vacancy-id="<%= vacancy._id %>" 
              data-vacancy-title="<%= vacancy.title %>"
              data-company="<%= vacancy.company %>"
              data-location="<%= vacancy.location %>"
              data-salary="<%= vacancy.salary %>"
              data-hours-per-week="<%= vacancy.hoursPerWeek %>"
              data-contract-type="<%= vacancy.contractType %>">
              &#10003;
            </button>
          </div>

        </div>

      <% }) %>

    </section>

  </main>

  <script src="/js/matching.js"></script>

  <%- include("../partials/footer") %>