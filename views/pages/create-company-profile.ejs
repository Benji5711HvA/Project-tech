<%- include("../partials/head") %>

<main class="account">

  <div class="account-left">
    <img src="/images/gradient-wave.png" alt="Collego illustratie" />
    <span class="logo">Collego</span>
    <div class="text">
      <h2>Vertel ons over<br>je bedrijf!</h2>
      <p>Vul je bedrijfsprofiel in en vind de beste kandidaten voor jouw vacatures.</p>
    </div>
  </div>

  <section class="account-right">
    <div class="container">

      <h1>Bedrijfsprofiel <span>aanmaken</span></h1>
      <p class="subtitle">Vertel werkzoekenden wie jullie zijn en wat jullie doen.</p>

      <form action="/create-company-profile" method="POST" enctype="multipart/form-data">

        <div class="field">
          <label for="companyName">Bedrijfsnaam</label>
          <input type="text" id="companyName" name="companyName" placeholder="Bijv. Zorgwerk B.V." required />
        </div>

        <div class="field">
          <label>Tot welke sector behoort jouw bedrijf?</label>
          <div class="sector-grid">
            <div class="sector-card">
              <input type="radio" id="sector-ict" name="sector" value="it-jobs" />
              <label for="sector-ict">ICT & Tech</label>
            </div>
            <div class="sector-card">
              <input type="radio" id="sector-zorg" name="sector" value="healthcare-nursing-jobs" />
              <label for="sector-zorg">Zorg & Welzijn</label>
            </div>
            <div class="sector-card">
              <input type="radio" id="sector-admin" name="sector" value="admin-jobs" />
              <label for="sector-admin">Administratie</label>
            </div>
            <div class="sector-card">
              <input type="radio" id="sector-retail" name="sector" value="retail-jobs" />
              <label for="sector-retail">Retail & Verkoop</label>
            </div>
            <div class="sector-card">
              <input type="radio" id="sector-horeca" name="sector" value="hospitality-catering-jobs" />
              <label for="sector-horeca">Horeca & Toerisme</label>
            </div>
            <div class="sector-card">
              <input type="radio" id="sector-onderwijs" name="sector" value="teaching-jobs" />
              <label for="sector-onderwijs">Onderwijs</label>
            </div>
            <div class="sector-card">
              <input type="radio" id="sector-logistiek" name="sector" value="logistics-warehouse-jobs" />
              <label for="sector-logistiek">Logistiek</label>
            </div>
            <div class="sector-card">
              <input type="radio" id="sector-marketing" name="sector" value="pr-advertising-marketing-jobs" />
              <label for="sector-marketing">Marketing & Comm.</label>
            </div>
            <div class="sector-card">
              <input type="radio" id="sector-techniek" name="sector" value="industrial-jobs" />
              <label for="sector-techniek">Techniek & Industrie</label>
            </div>
            <div class="sector-card">
              <input type="radio" id="sector-finance" name="sector" value="accounting-finance-jobs" />
              <label for="sector-finance">Finance & Juridisch</label>
            </div>
            <div class="sector-card">
              <input type="radio" id="sector-bouw" name="sector" value="construction-jobs" />
              <label for="sector-bouw">Bouw & Infra</label>
            </div>
          </div>
        </div>

        <div class="field">
          <label for="website">Website <span class="optional">(optioneel)</span></label>
          <input type="url" id="website" name="website" placeholder="https://www.jouwbedrijf.nl" />
        </div>

        <div class="field">
          <label>Bedrijfsgrootte</label>
          <div class="chip-group">
            <div class="chip">
              <input type="radio" id="size-1" name="companySize" value="1-10" />
              <label for="size-1">1 - 10</label>
            </div>
            <div class="chip">
              <input type="radio" id="size-2" name="companySize" value="11-50" />
              <label for="size-2">11 - 50</label>
            </div>
            <div class="chip">
              <input type="radio" id="size-3" name="companySize" value="51-200" />
              <label for="size-3">51 - 200</label>
            </div>
            <div class="chip">
              <input type="radio" id="size-4" name="companySize" value="201-500" />
              <label for="size-4">201 - 500</label>
            </div>
            <div class="chip">
              <input type="radio" id="size-5" name="companySize" value="500+" />
              <label for="size-5">500+</label>
            </div>
          </div>
        </div>

        <div class="field">
          <label for="logo">Bedrijfslogo <span class="optional">(optioneel)</span></label>
          <div class="file-upload">
            <input type="file" id="logo" name="logo" accept="image/*" onchange="logoSelected(this)" />
            <p>Sleep je logo hierheen of <strong>klik om te uploaden</strong></p>
            <p class="file-sub">PNG of JPG - max 2MB</p>
          </div>
          <p class="file-name" id="logoFilename"></p>
        </div>

        <div class="field">
          <label for="description">Over ons <span class="optional">(optioneel)</span></label>
          <textarea id="description" name="description" maxlength="300" oninput="updateTeller(this.value.length)" placeholder="Vertel kort over je bedrijf, cultuur en wat jullie doen..."></textarea>
          <p class="teller">0/300</p>
        </div>

        <% if (typeof error !=='undefined' ) { %>
        <div class="error">
          <%= error %>
        </div>
        <% } %>

        <button type="submit" class="btn">Bedrijfsprofiel aanmaken</button>

      </form>
    </div>
  </section>

</main>

<script src="/js/create-company-profile.js"></script>

<%- include("../partials/foot") %>